{
  "name": "geo-rag-planning-assistant-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/sync-cesium-assets.mjs",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "prebuild": "node ./scripts/sync-cesium-assets.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "api:export": "node ./scripts/export-openapi.mjs",
    "api:generate": "npm run api:export && openapi-typescript ./src/lib/api/generated/openapi.json -o ./src/lib/api/generated/schema.d.ts --default-non-nullable false --empty-objects-unknown",
    "contract:check": "node ./scripts/check-api-contract-usage.mjs",
    "lint": "node ./scripts/check-text-encoding.mjs && npm run contract:check && tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "cesium": "^1.140.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ol": "^10.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
