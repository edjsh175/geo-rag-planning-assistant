# Docker compose variable examples (prefixed to avoid collisions with local app .env)
GEOAI_POSTGRES_DB=geoai_db
GEOAI_POSTGRES_USER=postgres
GEOAI_POSTGRES_PASSWORD=change_me_postgres

GEOAI_MYSQL_DATABASE=disaster_knowledge
GEOAI_MYSQL_ROOT_PASSWORD=change_me_mysql

GEOAI_DATABASE_URL=postgresql+asyncpg://postgres:change_me_postgres@postgis:5432/geoai_db
GEOAI_MYSQL_URL=mysql+aiomysql://root:change_me_mysql@mysql:3306/disaster_knowledge
GEOAI_REDIS_URL=redis://:change_me_redis@redis:6379/0

GEOAI_MINIO_ENDPOINT=minio:9000
GEOAI_MINIO_ACCESS_KEY=minioadmin
GEOAI_MINIO_SECRET_KEY=change_me_minio
GEOAI_MINIO_BUCKET=geoai-assets
GEOAI_MINIO_ROOT_USER=minioadmin
GEOAI_MINIO_ROOT_PASSWORD=change_me_minio

GEOAI_GEOSERVER_URL=http://geoserver:8080/geoserver
GEOAI_REDIS_PASSWORD=change_me_redis

# Optional LLM keys passed through to backend container
ZHIPU_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

GEOAI_ZHIPU_API_KEY=
GEOAI_OPENAI_API_KEY=
GEOAI_DEEPSEEK_API_KEY=

