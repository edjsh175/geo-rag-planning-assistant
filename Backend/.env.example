# GeoAI backend local environment example
DEBUG=True
HOST=127.0.0.1
PORT=8000

# Required local databases
# PostgreSQL stores vector chunks and spatial data.
DATABASE_URL=postgresql+asyncpg://geoai:replace_with_local_password@127.0.0.1:5432/geoai_db

# MySQL stores standard metadata in standard_norm_detail.
MYSQL_URL=mysql+aiomysql://geoai_mysql:replace_with_local_password@127.0.0.1:3306/geoai_metadata

# Redis is an optional cache. Backend startup does not fail if it is unavailable.
REDIS_URL=redis://127.0.0.1:6379/0

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# Optional providers
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Security
SECRET_KEY=replace_with_local_random_value
SYSTEM_API_KEY=replace_with_local_system_key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional future object-storage workflow for cited document downloads.
# Leave these unset unless MinIO is installed and the document download workflow is enabled.
# MINIO_URL=127.0.0.1:9000
# MINIO_ACCESS_KEY=replace_with_minio_user
# MINIO_SECRET_KEY=replace_with_minio_password
# MINIO_BUCKET=geoai-assets
# MINIO_SECURE=False

# Upload
MAX_UPLOAD_SIZE=104857600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/geoai.log
