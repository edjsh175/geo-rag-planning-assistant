# GeoAI 后端环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# 应用配置
DEBUG=True
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/geoai_db
MYSQL_URL=mysql+aiomysql://root:password@localhost:3306/geoai_metadata
REDIS_URL=redis://localhost:6379/0

# 大模型配置
LLM_PROVIDER=openai  # 支持: openai, zhipu, deepseek
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# 智谱AI配置（如果使用）
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4

# DeepSeek配置（如果使用）
DEEPSEEK_API_KEY=sk-463c7438a98b48a1ba9bca37e0193791
DEEPSEEK_MODEL=deepseek-chat

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传配置
MAX_UPLOAD_SIZE=104857600  # 100MB

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/geoai.log